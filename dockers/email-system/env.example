STACK_PROJECT_NAME=houmao-email-system # Docker Compose project name for the local email stack.
STALWART_IMAGE=stalwartlabs/stalwart:latest # Preloaded local Stalwart image tag; startup uses it without pulling.
POSTGRES_IMAGE=postgres:14.22 # Preloaded local Postgres image tag for Cypht's database-backed state.
CYPHT_IMAGE=cypht/cypht:latest # Preloaded local Cypht image tag; startup uses it without pulling.
MAIL_DOMAIN=example.test # Mail domain that the provisioning helper creates in Stalwart.
STALWART_HOSTNAME=mail.example.test # Hostname advertised by Stalwart for the local development mail system.
STALWART_BOOTSTRAP_USER=bootstrap # Hidden fallback-admin username used only by the provisioning helper to bootstrap the real admin mailbox.
STALWART_BOOTSTRAP_PASSWORD=admin # Hidden fallback-admin password used only by the provisioning helper during local bring-up.
STALWART_ADMIN_USER=admin # Provisioned Stalwart superuser mailbox login for webadmin, the management API, IMAP, and SMTP auth.
STALWART_ADMIN_PASSWORD=admin # Password assigned to the provisioned Stalwart superuser mailbox login.
SEED_MAILBOX_NAME=admin # Default mailbox principal created for the first login and verification flow.
SEED_MAILBOX_PASSWORD=admin # Password assigned to the default seeded mailbox principal.
SEED_MAILBOX_EMAIL=admin@example.test # Primary email address assigned to the default seeded mailbox principal.
STALWART_HTTP_PORT=10080 # High-port HTTP listener exposed for Stalwart webadmin and the management API.
STALWART_IMAP_PORT=10143 # High-port IMAP listener used by Cypht for mailbox authentication and reads.
STALWART_SUBMISSION_PORT=10587 # High-port SMTP submission listener used by Cypht for sending mail.
POSTGRES_PORT=15432 # High-port Postgres listener used by Cypht for database-backed session state.
POSTGRES_DB=cypht # Postgres database name created for the Cypht application state.
POSTGRES_USER=admin # Postgres username that Cypht uses for its application database.
POSTGRES_PASSWORD=admin # Postgres password that Cypht uses for its application database.
CYPHT_HTTP_PORT=10081 # High-port Cypht web UI listener exposed on the host.
CYPHT_DB_DRIVER=pgsql # Database driver that Cypht uses to connect to the Postgres sidecar.
CYPHT_SESSION_TYPE=DB # Cypht session backend; DB stores session state in Postgres.
CYPHT_AUTH_TYPE=IMAP # Cypht authentication backend; IMAP delegates login to Stalwart.
CYPHT_IMAP_AUTH_NAME="Stalwart Dev" # UI label shown by Cypht for the IMAP authentication source.
CYPHT_IMAP_AUTH_TLS=false # Disable IMAP TLS because the local stack uses plain IMAP on the Docker network.
CYPHT_DEFAULT_SMTP_NAME="Stalwart Submission" # UI label shown by Cypht for the default SMTP submission server.
CYPHT_DEFAULT_SMTP_TLS=false # Disable SMTP TLS because the local stack uses plain SMTP submission on the Docker network.
CYPHT_DEFAULT_SMTP_NO_AUTH=false # Keep SMTP auth enabled so Cypht reuses the mailbox login credentials.
CYPHT_USER_CONFIG_TYPE=file # Store Cypht user settings as files under .data/cypht/users.
CYPHT_USER_SETTINGS_DIR=/var/lib/hm3/users # Container path where Cypht persists file-backed user settings.
CYPHT_ATTACHMENT_DIR=/var/lib/hm3/attachments # Container path where Cypht persists uploaded attachments.
CYPHT_SINGLE_SERVER_MODE=true # Restrict Cypht to the Stalwart-backed mail source only.
CYPHT_AUTO_CREATE_PROFILE=true # Auto-create a default sender profile after successful IMAP login.
CYPHT_DISABLE_ORIGIN_CHECK=true # Relax origin checking for local compose-based development access.
