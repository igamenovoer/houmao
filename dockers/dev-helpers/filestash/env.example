# Compose project name used for the local Filestash helper stack.
STACK_PROJECT_NAME=houmao-dev-helper-filestash

# Loopback-only host port for the Filestash web UI. Keep this >=10000.
FILESTASH_HTTP_PORT=18334

# Container path where the repository is mounted read-only.
FILESTASH_REPO_MOUNT_PATH=/repo

# Operator-facing connection label exposed by the helper.
FILESTASH_CONNECTION_LABEL=Repo

# Default development password accepted by the seeded Filestash login flow.
FILESTASH_DEFAULT_PASSWORD=admin
