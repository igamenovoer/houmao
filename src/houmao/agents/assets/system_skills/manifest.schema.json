{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "auto_skill_name", "defaults", "packs", "public_skills", "protected_mounts", "protected_routines", "legacy_skills"],
  "properties": {
    "schema_version": {"const": "houmao-system-skills.v2"},
    "auto_skill_name": {"const": "houmao-auto-system-prompt"},
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cli", "managed_launch", "managed_join"],
      "properties": {
        "cli": {"$ref": "#/$defs/packIds"},
        "managed_launch": {"$ref": "#/$defs/packIds"},
        "managed_join": {"$ref": "#/$defs/packIds"}
      }
    },
    "packs": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/pack"}},
    "public_skills": {"type": "array", "minItems": 3, "items": {"$ref": "#/$defs/publicSkill"}},
    "protected_mounts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/protectedMount"}},
    "protected_routines": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/protectedRoutine"}},
    "legacy_skills": {"type": "array", "items": {"$ref": "#/$defs/legacySkill"}}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "skillName": {"type": "string", "pattern": "^houmao-[a-z0-9-]+$"},
    "relativePath": {"type": "string", "pattern": "^[A-Za-z0-9._/-]+$"},
    "stringList": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "packIds": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pack_id", "audience", "description", "public_skills", "protected_mounts", "default_lanes"],
      "properties": {
        "pack_id": {"$ref": "#/$defs/id"},
        "audience": {"enum": ["admin", "agent"]},
        "description": {"type": "string", "minLength": 1},
        "public_skills": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/skillName"}, "uniqueItems": true},
        "protected_mounts": {"type": "array", "items": {"$ref": "#/$defs/skillName"}, "uniqueItems": true},
        "default_lanes": {"type": "array", "items": {"enum": ["cli", "managed_launch", "managed_join"]}, "uniqueItems": true}
      }
    },
    "publicSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "pack_id", "role", "source_path", "public_commands"],
      "properties": {
        "name": {"$ref": "#/$defs/skillName"},
        "pack_id": {"$ref": "#/$defs/id"},
        "role": {"enum": ["welcome", "entrypoint"]},
        "source_path": {"$ref": "#/$defs/relativePath"},
        "public_commands": {"$ref": "#/$defs/stringList"},
        "handoff_to": {"$ref": "#/$defs/skillName"},
        "welcome_delegate": {"$ref": "#/$defs/skillName"}
      }
    },
    "protectedMount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mount_id", "source_path", "member_name", "admin_route_path", "agent_route_path", "shared_paths"],
      "properties": {
        "mount_id": {"$ref": "#/$defs/skillName"},
        "source_path": {"$ref": "#/$defs/relativePath"},
        "member_name": {"$ref": "#/$defs/skillName"},
        "admin_route_path": {"$ref": "#/$defs/relativePath"},
        "agent_route_path": {"$ref": "#/$defs/relativePath"},
        "shared_paths": {"$ref": "#/$defs/stringList"}
      }
    },
    "protectedRoutine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logical_id", "source_path", "member_name", "route_name", "audiences", "dependencies", "commands"],
      "properties": {
        "logical_id": {"$ref": "#/$defs/skillName"},
        "source_path": {"$ref": "#/$defs/relativePath"},
        "member_name": {"$ref": "#/$defs/skillName"},
        "route_name": {"$ref": "#/$defs/id"},
        "audiences": {"type": "array", "minItems": 1, "items": {"enum": ["admin", "agent"]}, "uniqueItems": true},
        "dependencies": {"type": "array", "items": {"$ref": "#/$defs/skillName"}, "uniqueItems": true},
        "commands": {"$ref": "#/$defs/stringList"}
      }
    },
    "legacySkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "asset_subpath", "content_digest"],
      "properties": {
        "name": {"$ref": "#/$defs/skillName"},
        "asset_subpath": {"$ref": "#/$defs/relativePath"},
        "content_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    }
  }
}
