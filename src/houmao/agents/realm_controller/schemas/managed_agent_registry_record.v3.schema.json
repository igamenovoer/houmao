{
  "$defs": {
    "RegistryGatewayV1": {
      "additionalProperties": false,
      "description": "Optional live gateway connect metadata published into the registry.",
      "properties": {
        "host": {
          "enum": [
            "127.0.0.1",
            "0.0.0.0"
          ],
          "title": "Host",
          "type": "string"
        },
        "port": {
          "title": "Port",
          "type": "integer"
        },
        "state_path": {
          "title": "State Path",
          "type": "string"
        },
        "protocol_version": {
          "const": "v1",
          "title": "Protocol Version",
          "type": "string"
        }
      },
      "required": [
        "host",
        "port",
        "state_path",
        "protocol_version"
      ],
      "title": "RegistryGatewayV1",
      "type": "object"
    },
    "RegistryIdentityV1": {
      "additionalProperties": false,
      "description": "Identity metadata for one published managed-agent record.",
      "properties": {
        "backend": {
          "enum": [
            "local_interactive",
            "codex_headless",
            "codex_app_server",
            "claude_headless",
            "gemini_headless",
            "cao_rest",
            "houmao_server_rest"
          ],
          "title": "Backend",
          "type": "string"
        },
        "tool": {
          "title": "Tool",
          "type": "string"
        }
      },
      "required": [
        "backend",
        "tool"
      ],
      "title": "RegistryIdentityV1",
      "type": "object"
    },
    "RegistryLifecycleV1": {
      "additionalProperties": false,
      "description": "Lifecycle metadata for one managed-agent registry record.",
      "properties": {
        "state": {
          "enum": [
            "active",
            "stopped",
            "relaunching",
            "retired"
          ],
          "title": "State",
          "type": "string"
        },
        "relaunchable": {
          "title": "Relaunchable",
          "type": "boolean"
        },
        "state_updated_at": {
          "title": "State Updated At",
          "type": "string"
        },
        "stopped_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stopped At"
        },
        "stop_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stop Reason"
        }
      },
      "required": [
        "state",
        "relaunchable",
        "state_updated_at"
      ],
      "title": "RegistryLifecycleV1",
      "type": "object"
    },
    "RegistryLivenessV1": {
      "additionalProperties": false,
      "description": "Active-only liveness metadata for one managed-agent record.",
      "properties": {
        "published_at": {
          "title": "Published At",
          "type": "string"
        },
        "lease_expires_at": {
          "title": "Lease Expires At",
          "type": "string"
        }
      },
      "required": [
        "published_at",
        "lease_expires_at"
      ],
      "title": "RegistryLivenessV1",
      "type": "object"
    },
    "RegistryMailboxFilesystemV1": {
      "additionalProperties": false,
      "description": "Filesystem mailbox identity metadata for one published managed-agent session.",
      "properties": {
        "transport": {
          "const": "filesystem",
          "title": "Transport",
          "type": "string"
        },
        "principal_id": {
          "title": "Principal Id",
          "type": "string"
        },
        "address": {
          "title": "Address",
          "type": "string"
        },
        "filesystem_root": {
          "title": "Filesystem Root",
          "type": "string"
        },
        "bindings_version": {
          "title": "Bindings Version",
          "type": "string"
        }
      },
      "required": [
        "transport",
        "principal_id",
        "address",
        "filesystem_root",
        "bindings_version"
      ],
      "title": "RegistryMailboxFilesystemV1",
      "type": "object"
    },
    "RegistryMailboxStalwartV1": {
      "additionalProperties": false,
      "description": "Stalwart mailbox identity metadata for one published managed-agent session.",
      "properties": {
        "transport": {
          "const": "stalwart",
          "title": "Transport",
          "type": "string"
        },
        "principal_id": {
          "title": "Principal Id",
          "type": "string"
        },
        "address": {
          "title": "Address",
          "type": "string"
        },
        "bindings_version": {
          "title": "Bindings Version",
          "type": "string"
        },
        "jmap_url": {
          "title": "Jmap Url",
          "type": "string"
        },
        "management_url": {
          "title": "Management Url",
          "type": "string"
        },
        "login_identity": {
          "title": "Login Identity",
          "type": "string"
        },
        "credential_ref": {
          "title": "Credential Ref",
          "type": "string"
        }
      },
      "required": [
        "transport",
        "principal_id",
        "address",
        "bindings_version",
        "jmap_url",
        "management_url",
        "login_identity",
        "credential_ref"
      ],
      "title": "RegistryMailboxStalwartV1",
      "type": "object"
    },
    "RegistryRuntimeV1": {
      "additionalProperties": false,
      "description": "Pointers to runtime-owned state for one managed-agent record.",
      "properties": {
        "manifest_path": {
          "title": "Manifest Path",
          "type": "string"
        },
        "session_root": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Session Root"
        },
        "agent_def_dir": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agent Def Dir"
        }
      },
      "required": [
        "manifest_path"
      ],
      "title": "RegistryRuntimeV1",
      "type": "object"
    },
    "RegistryTerminalV2": {
      "additionalProperties": false,
      "description": "Terminal-container hints for lifecycle-aware registry payloads.",
      "properties": {
        "kind": {
          "const": "tmux",
          "default": "tmux",
          "title": "Kind",
          "type": "string"
        },
        "current_session_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Current Session Name"
        },
        "last_session_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Session Name"
        }
      },
      "title": "RegistryTerminalV2",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Lifecycle-aware shared-registry ``record.json`` contract.",
  "properties": {
    "schema_version": {
      "default": 3,
      "title": "Schema Version",
      "type": "integer"
    },
    "agent_name": {
      "title": "Agent Name",
      "type": "string"
    },
    "agent_id": {
      "title": "Agent Id",
      "type": "string"
    },
    "generation_id": {
      "title": "Generation Id",
      "type": "string"
    },
    "lifecycle": {
      "$ref": "#/$defs/RegistryLifecycleV1"
    },
    "identity": {
      "$ref": "#/$defs/RegistryIdentityV1"
    },
    "runtime": {
      "$ref": "#/$defs/RegistryRuntimeV1"
    },
    "terminal": {
      "$ref": "#/$defs/RegistryTerminalV2"
    },
    "liveness": {
      "anyOf": [
        {
          "$ref": "#/$defs/RegistryLivenessV1"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "gateway": {
      "anyOf": [
        {
          "$ref": "#/$defs/RegistryGatewayV1"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "mailbox": {
      "anyOf": [
        {
          "discriminator": {
            "mapping": {
              "filesystem": "#/$defs/RegistryMailboxFilesystemV1",
              "stalwart": "#/$defs/RegistryMailboxStalwartV1"
            },
            "propertyName": "transport"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/RegistryMailboxFilesystemV1"
            },
            {
              "$ref": "#/$defs/RegistryMailboxStalwartV1"
            }
          ]
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Mailbox"
    }
  },
  "required": [
    "agent_name",
    "agent_id",
    "generation_id",
    "lifecycle",
    "identity",
    "runtime",
    "terminal"
  ],
  "title": "ManagedAgentRegistryRecordV3",
  "type": "object"
}
