{
  "$defs": {
    "CaoSectionV2": {
      "additionalProperties": false,
      "description": "Persisted CAO backend section.",
      "properties": {
        "api_base_url": {
          "title": "Api Base Url",
          "type": "string"
        },
        "session_name": {
          "title": "Session Name",
          "type": "string"
        },
        "terminal_id": {
          "title": "Terminal Id",
          "type": "string"
        },
        "profile_name": {
          "title": "Profile Name",
          "type": "string"
        },
        "profile_path": {
          "title": "Profile Path",
          "type": "string"
        },
        "tmux_window_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tmux Window Name"
        },
        "parsing_mode": {
          "enum": [
            "cao_only",
            "shadow_only"
          ],
          "title": "Parsing Mode",
          "type": "string"
        },
        "turn_index": {
          "default": 0,
          "title": "Turn Index",
          "type": "integer"
        }
      },
      "required": [
        "api_base_url",
        "session_name",
        "terminal_id",
        "profile_name",
        "profile_path",
        "parsing_mode"
      ],
      "title": "CaoSectionV2",
      "type": "object"
    },
    "CodexSectionV1": {
      "additionalProperties": false,
      "description": "Persisted codex backend section.",
      "properties": {
        "thread_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Thread Id"
        },
        "turn_index": {
          "title": "Turn Index",
          "type": "integer"
        },
        "pid": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pid"
        },
        "process_started_at_utc": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Process Started At Utc"
        }
      },
      "required": [
        "thread_id",
        "turn_index"
      ],
      "title": "CodexSectionV1",
      "type": "object"
    },
    "HeadlessSectionV1": {
      "additionalProperties": false,
      "description": "Persisted headless backend section.",
      "properties": {
        "session_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Session Id"
        },
        "turn_index": {
          "title": "Turn Index",
          "type": "integer"
        },
        "role_bootstrap_applied": {
          "title": "Role Bootstrap Applied",
          "type": "boolean"
        },
        "working_directory": {
          "title": "Working Directory",
          "type": "string"
        }
      },
      "required": [
        "session_id",
        "turn_index",
        "role_bootstrap_applied",
        "working_directory"
      ],
      "title": "HeadlessSectionV1",
      "type": "object"
    },
    "HoumaoServerSectionV1": {
      "additionalProperties": false,
      "description": "Persisted `houmao_server_rest` backend section.",
      "properties": {
        "api_base_url": {
          "title": "Api Base Url",
          "type": "string"
        },
        "session_name": {
          "title": "Session Name",
          "type": "string"
        },
        "terminal_id": {
          "title": "Terminal Id",
          "type": "string"
        },
        "parsing_mode": {
          "enum": [
            "cao_only",
            "shadow_only"
          ],
          "title": "Parsing Mode",
          "type": "string"
        },
        "tmux_window_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tmux Window Name"
        },
        "turn_index": {
          "default": 0,
          "title": "Turn Index",
          "type": "integer"
        }
      },
      "required": [
        "api_base_url",
        "session_name",
        "terminal_id",
        "parsing_mode"
      ],
      "title": "HoumaoServerSectionV1",
      "type": "object"
    },
    "LaunchPlanHomeSelectorV1": {
      "additionalProperties": false,
      "description": "`home_selector` payload for `launch_plan.v1`.",
      "properties": {
        "env_var": {
          "title": "Env Var",
          "type": "string"
        },
        "home_path": {
          "title": "Home Path",
          "type": "string"
        }
      },
      "required": [
        "env_var",
        "home_path"
      ],
      "title": "LaunchPlanHomeSelectorV1",
      "type": "object"
    },
    "LaunchPlanMailboxFilesystemV1": {
      "additionalProperties": false,
      "description": "Persisted filesystem mailbox binding for `launch_plan.v1`.",
      "properties": {
        "transport": {
          "const": "filesystem",
          "title": "Transport",
          "type": "string"
        },
        "principal_id": {
          "title": "Principal Id",
          "type": "string"
        },
        "address": {
          "title": "Address",
          "type": "string"
        },
        "bindings_version": {
          "title": "Bindings Version",
          "type": "string"
        },
        "filesystem_root": {
          "title": "Filesystem Root",
          "type": "string"
        }
      },
      "required": [
        "transport",
        "principal_id",
        "address",
        "bindings_version",
        "filesystem_root"
      ],
      "title": "LaunchPlanMailboxFilesystemV1",
      "type": "object"
    },
    "LaunchPlanMailboxStalwartV1": {
      "additionalProperties": false,
      "description": "Persisted Stalwart mailbox binding for `launch_plan.v1`.",
      "properties": {
        "transport": {
          "const": "stalwart",
          "title": "Transport",
          "type": "string"
        },
        "principal_id": {
          "title": "Principal Id",
          "type": "string"
        },
        "address": {
          "title": "Address",
          "type": "string"
        },
        "bindings_version": {
          "title": "Bindings Version",
          "type": "string"
        },
        "jmap_url": {
          "title": "Jmap Url",
          "type": "string"
        },
        "management_url": {
          "title": "Management Url",
          "type": "string"
        },
        "login_identity": {
          "title": "Login Identity",
          "type": "string"
        },
        "credential_ref": {
          "title": "Credential Ref",
          "type": "string"
        }
      },
      "required": [
        "transport",
        "principal_id",
        "address",
        "bindings_version",
        "jmap_url",
        "management_url",
        "login_identity",
        "credential_ref"
      ],
      "title": "LaunchPlanMailboxStalwartV1",
      "type": "object"
    },
    "LaunchPlanPayloadV1": {
      "additionalProperties": false,
      "description": "Persisted `launch_plan.v1` payload.",
      "properties": {
        "backend": {
          "enum": [
            "codex_headless",
            "codex_app_server",
            "claude_headless",
            "gemini_headless",
            "cao_rest",
            "houmao_server_rest"
          ],
          "title": "Backend",
          "type": "string"
        },
        "tool": {
          "title": "Tool",
          "type": "string"
        },
        "executable": {
          "title": "Executable",
          "type": "string"
        },
        "args": {
          "items": {
            "type": "string"
          },
          "title": "Args",
          "type": "array"
        },
        "working_directory": {
          "title": "Working Directory",
          "type": "string"
        },
        "home_selector": {
          "$ref": "#/$defs/LaunchPlanHomeSelectorV1"
        },
        "env_var_names": {
          "items": {
            "type": "string"
          },
          "title": "Env Var Names",
          "type": "array"
        },
        "role_injection": {
          "$ref": "#/$defs/LaunchPlanRoleInjectionV1"
        },
        "metadata": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              },
              {
                "items": {},
                "type": "array"
              },
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Metadata",
          "type": "object"
        },
        "mailbox": {
          "anyOf": [
            {
              "discriminator": {
                "mapping": {
                  "filesystem": "#/$defs/LaunchPlanMailboxFilesystemV1",
                  "stalwart": "#/$defs/LaunchPlanMailboxStalwartV1"
                },
                "propertyName": "transport"
              },
              "oneOf": [
                {
                  "$ref": "#/$defs/LaunchPlanMailboxFilesystemV1"
                },
                {
                  "$ref": "#/$defs/LaunchPlanMailboxStalwartV1"
                }
              ]
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mailbox"
        },
        "launch_policy_provenance": {
          "anyOf": [
            {
              "$ref": "#/$defs/LaunchPolicyProvenanceV1"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "backend",
        "tool",
        "executable",
        "args",
        "working_directory",
        "home_selector",
        "env_var_names",
        "role_injection",
        "metadata"
      ],
      "title": "LaunchPlanPayloadV1",
      "type": "object"
    },
    "LaunchPlanRoleInjectionV1": {
      "additionalProperties": false,
      "description": "`role_injection` payload for `launch_plan.v1`.",
      "properties": {
        "method": {
          "enum": [
            "native_developer_instructions",
            "native_append_system_prompt",
            "bootstrap_message",
            "cao_profile"
          ],
          "title": "Method",
          "type": "string"
        },
        "role_name": {
          "title": "Role Name",
          "type": "string"
        }
      },
      "required": [
        "method",
        "role_name"
      ],
      "title": "LaunchPlanRoleInjectionV1",
      "type": "object"
    },
    "LaunchPolicyProvenanceV1": {
      "additionalProperties": false,
      "description": "Typed launch-policy provenance persisted in launch/session payloads.",
      "properties": {
        "requested_operator_prompt_mode": {
          "enum": [
            "interactive",
            "unattended"
          ],
          "title": "Requested Operator Prompt Mode",
          "type": "string"
        },
        "detected_tool_version": {
          "title": "Detected Tool Version",
          "type": "string"
        },
        "selected_strategy_id": {
          "title": "Selected Strategy Id",
          "type": "string"
        },
        "selection_source": {
          "enum": [
            "registry",
            "env_override"
          ],
          "title": "Selection Source",
          "type": "string"
        },
        "override_env_var_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Override Env Var Name"
        }
      },
      "required": [
        "requested_operator_prompt_mode",
        "detected_tool_version",
        "selected_strategy_id",
        "selection_source"
      ],
      "title": "LaunchPolicyProvenanceV1",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Persisted ``session_manifest.v3`` payload.",
  "properties": {
    "schema_version": {
      "title": "Schema Version",
      "type": "integer"
    },
    "backend": {
      "enum": [
        "codex_headless",
        "codex_app_server",
        "claude_headless",
        "gemini_headless",
        "cao_rest",
        "houmao_server_rest"
      ],
      "title": "Backend",
      "type": "string"
    },
    "tool": {
      "title": "Tool",
      "type": "string"
    },
    "role_name": {
      "title": "Role Name",
      "type": "string"
    },
    "created_at_utc": {
      "title": "Created At Utc",
      "type": "string"
    },
    "working_directory": {
      "title": "Working Directory",
      "type": "string"
    },
    "brain_manifest_path": {
      "title": "Brain Manifest Path",
      "type": "string"
    },
    "agent_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Agent Name"
    },
    "agent_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Agent Id"
    },
    "tmux_session_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tmux Session Name"
    },
    "job_dir": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Job Dir"
    },
    "registry_generation_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Registry Generation Id"
    },
    "registry_launch_authority": {
      "default": "runtime",
      "enum": [
        "runtime",
        "external"
      ],
      "title": "Registry Launch Authority",
      "type": "string"
    },
    "launch_plan": {
      "$ref": "#/$defs/LaunchPlanPayloadV1"
    },
    "launch_policy_provenance": {
      "anyOf": [
        {
          "$ref": "#/$defs/LaunchPolicyProvenanceV1"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "backend_state": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "integer"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          },
          {
            "items": {},
            "type": "array"
          },
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "null"
          }
        ]
      },
      "title": "Backend State",
      "type": "object"
    },
    "codex": {
      "anyOf": [
        {
          "$ref": "#/$defs/CodexSectionV1"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "headless": {
      "anyOf": [
        {
          "$ref": "#/$defs/HeadlessSectionV1"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "cao": {
      "anyOf": [
        {
          "$ref": "#/$defs/CaoSectionV2"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "houmao_server": {
      "anyOf": [
        {
          "$ref": "#/$defs/HoumaoServerSectionV1"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "schema_version",
    "backend",
    "tool",
    "role_name",
    "created_at_utc",
    "working_directory",
    "brain_manifest_path",
    "launch_plan",
    "backend_state"
  ],
  "title": "SessionManifestPayloadV3",
  "type": "object"
}
