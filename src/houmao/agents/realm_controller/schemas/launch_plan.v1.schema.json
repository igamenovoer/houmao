{
  "$defs": {
    "LaunchPlanHomeSelectorV1": {
      "additionalProperties": false,
      "description": "`home_selector` payload for `launch_plan.v1`.",
      "properties": {
        "env_var": {
          "title": "Env Var",
          "type": "string"
        },
        "home_path": {
          "title": "Home Path",
          "type": "string"
        }
      },
      "required": [
        "env_var",
        "home_path"
      ],
      "title": "LaunchPlanHomeSelectorV1",
      "type": "object"
    },
    "LaunchPlanMailboxFilesystemV1": {
      "additionalProperties": false,
      "description": "Persisted filesystem mailbox binding for `launch_plan.v1`.",
      "properties": {
        "address": {
          "title": "Address",
          "type": "string"
        },
        "bindings_version": {
          "title": "Bindings Version",
          "type": "string"
        },
        "filesystem_root": {
          "title": "Filesystem Root",
          "type": "string"
        },
        "principal_id": {
          "title": "Principal Id",
          "type": "string"
        },
        "transport": {
          "const": "filesystem",
          "title": "Transport",
          "type": "string"
        }
      },
      "required": [
        "transport",
        "principal_id",
        "address",
        "bindings_version",
        "filesystem_root"
      ],
      "title": "LaunchPlanMailboxFilesystemV1",
      "type": "object"
    },
    "LaunchPlanMailboxStalwartV1": {
      "additionalProperties": false,
      "description": "Persisted Stalwart mailbox binding for `launch_plan.v1`.",
      "properties": {
        "address": {
          "title": "Address",
          "type": "string"
        },
        "bindings_version": {
          "title": "Bindings Version",
          "type": "string"
        },
        "credential_ref": {
          "title": "Credential Ref",
          "type": "string"
        },
        "jmap_url": {
          "title": "Jmap Url",
          "type": "string"
        },
        "login_identity": {
          "title": "Login Identity",
          "type": "string"
        },
        "management_url": {
          "title": "Management Url",
          "type": "string"
        },
        "principal_id": {
          "title": "Principal Id",
          "type": "string"
        },
        "transport": {
          "const": "stalwart",
          "title": "Transport",
          "type": "string"
        }
      },
      "required": [
        "transport",
        "principal_id",
        "address",
        "bindings_version",
        "jmap_url",
        "management_url",
        "login_identity",
        "credential_ref"
      ],
      "title": "LaunchPlanMailboxStalwartV1",
      "type": "object"
    },
    "LaunchPlanRoleInjectionV1": {
      "additionalProperties": false,
      "description": "`role_injection` payload for `launch_plan.v1`.",
      "properties": {
        "method": {
          "enum": [
            "native_developer_instructions",
            "native_append_system_prompt",
            "bootstrap_message",
            "cao_profile"
          ],
          "title": "Method",
          "type": "string"
        },
        "role_name": {
          "title": "Role Name",
          "type": "string"
        }
      },
      "required": [
        "method",
        "role_name"
      ],
      "title": "LaunchPlanRoleInjectionV1",
      "type": "object"
    },
    "LaunchPolicyProvenanceV1": {
      "additionalProperties": false,
      "description": "Typed launch-policy provenance persisted in launch/session payloads.",
      "properties": {
        "detected_tool_version": {
          "title": "Detected Tool Version",
          "type": "string"
        },
        "override_env_var_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Override Env Var Name"
        },
        "requested_operator_prompt_mode": {
          "enum": [
            "as_is",
            "unattended"
          ],
          "title": "Requested Operator Prompt Mode",
          "type": "string"
        },
        "selected_strategy_id": {
          "title": "Selected Strategy Id",
          "type": "string"
        },
        "selection_source": {
          "enum": [
            "registry",
            "env_override"
          ],
          "title": "Selection Source",
          "type": "string"
        }
      },
      "required": [
        "requested_operator_prompt_mode",
        "detected_tool_version",
        "selected_strategy_id",
        "selection_source"
      ],
      "title": "LaunchPolicyProvenanceV1",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Persisted `launch_plan.v1` payload.",
  "properties": {
    "args": {
      "items": {
        "type": "string"
      },
      "title": "Args",
      "type": "array"
    },
    "backend": {
      "enum": [
        "local_interactive",
        "codex_headless",
        "codex_app_server",
        "claude_headless",
        "gemini_headless",
        "cao_rest",
        "houmao_server_rest"
      ],
      "title": "Backend",
      "type": "string"
    },
    "env_var_names": {
      "items": {
        "type": "string"
      },
      "title": "Env Var Names",
      "type": "array"
    },
    "executable": {
      "title": "Executable",
      "type": "string"
    },
    "home_selector": {
      "$ref": "#/$defs/LaunchPlanHomeSelectorV1"
    },
    "launch_policy_provenance": {
      "anyOf": [
        {
          "$ref": "#/$defs/LaunchPolicyProvenanceV1"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "mailbox": {
      "anyOf": [
        {
          "discriminator": {
            "mapping": {
              "filesystem": "#/$defs/LaunchPlanMailboxFilesystemV1",
              "stalwart": "#/$defs/LaunchPlanMailboxStalwartV1"
            },
            "propertyName": "transport"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/LaunchPlanMailboxFilesystemV1"
            },
            {
              "$ref": "#/$defs/LaunchPlanMailboxStalwartV1"
            }
          ]
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Mailbox"
    },
    "metadata": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "integer"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          },
          {
            "items": {},
            "type": "array"
          },
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "null"
          }
        ]
      },
      "title": "Metadata",
      "type": "object"
    },
    "role_injection": {
      "$ref": "#/$defs/LaunchPlanRoleInjectionV1"
    },
    "tool": {
      "title": "Tool",
      "type": "string"
    },
    "working_directory": {
      "title": "Working Directory",
      "type": "string"
    }
  },
  "required": [
    "backend",
    "tool",
    "executable",
    "args",
    "working_directory",
    "home_selector",
    "env_var_names",
    "role_injection",
    "metadata"
  ],
  "title": "LaunchPlanPayloadV1",
  "type": "object"
}
