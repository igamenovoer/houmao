{
  "id": "codex-explicit-success",
  "tool": "codex",
  "description": "Drive Codex through one simple explicit-input success turn.",
  "launch": {
    "settle_seconds": 1.0,
    "sample_interval_seconds": 0.25,
    "ready_timeout_seconds": 45.0
  },
  "steps": [
    {
      "action": "wait_for_ready",
      "name": "wait-for-ready"
    },
    {
      "action": "send_text",
      "name": "send-prompt",
      "text": "Reply with the single word READY and stop.",
      "submit": true
    },
    {
      "action": "wait_for_pattern",
      "name": "wait-for-ready-token",
      "pattern": "READY"
    },
    {
      "action": "wait_seconds",
      "name": "settle-success",
      "seconds": 2.0
    }
  ]
}

