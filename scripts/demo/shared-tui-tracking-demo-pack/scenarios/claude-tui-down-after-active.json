{
  "id": "claude-tui-down-after-active",
  "tool": "claude",
  "description": "Force a diagnostics-loss boundary by killing the tracked tmux session mid-turn.",
  "launch": {
    "settle_seconds": 1.0,
    "sample_interval_seconds": 0.25,
    "ready_timeout_seconds": 45.0
  },
  "steps": [
    {
      "action": "wait_for_ready",
      "name": "wait-for-ready"
    },
    {
      "action": "send_text",
      "name": "send-long-prompt",
      "text": "Think for a while and do not stop immediately.",
      "submit": true
    },
    {
      "action": "wait_seconds",
      "name": "let-active-surface-appear",
      "seconds": 1.0
    },
    {
      "action": "kill_session",
      "name": "kill-tracked-session"
    }
  ]
}

