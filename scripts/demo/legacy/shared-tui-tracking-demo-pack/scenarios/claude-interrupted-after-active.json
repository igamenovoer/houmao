{
  "id": "claude_interrupted_after_active",
  "tool": "claude",
  "description": "Interrupt an active Claude turn and keep the final interrupted posture visible.",
  "launch": {},
  "steps": [
    {
      "action": "wait_for_pattern",
      "name": "wait-for-workspace-trust-prompt",
      "pattern": "Enter to confirm",
      "timeout_seconds": 30.0
    },
    {
      "action": "send_key",
      "name": "confirm-workspace-trust",
      "key": "Enter"
    },
    {
      "action": "wait_for_ready",
      "name": "wait-for-ready"
    },
    {
      "action": "wait_for_pattern",
      "name": "wait-for-stable-input-surface",
      "pattern": "bypass permissions on",
      "timeout_seconds": 30.0
    },
    {
      "action": "send_text",
      "name": "send-long-prompt",
      "text": "Search this repository for files related to tmux and prepare a grouped summary. Think carefully before answering.",
      "submit": true
    },
    {
      "action": "wait_seconds",
      "name": "wait-for-active-surface",
      "seconds": 1.5
    },
    {
      "action": "interrupt_turn",
      "name": "interrupt",
    },
    {
      "action": "wait_for_interrupted_ready",
      "name": "wait-for-interrupted-ready"
    },
    {
      "action": "wait_seconds",
      "name": "hold-interrupted-surface",
      "seconds": 1.0
    }
  ]
}
