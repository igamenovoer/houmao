{
  "schema_version": 1,
  "provider": "codex",
  "calibrated_version": "0.144.3",
  "patterns": {
    "ready": {
      "regex": "(OpenAI Codex|permissions: YOLO mode|\u203a )",
      "description": "Codex CLI idle header or prompt glyph; confirmed present while ready.",
      "flags": 2
    },
    "active": {
      "regex": "(Esc to interrupt|Working\\s*\\(|Running\\s+(tool|command)|Starting MCP servers|background terminal running)",
      "description": "Codex active-turn status row.",
      "flags": 2
    },
    "pending": {
      "regex": "(Messages to be submitted after next tool call|messages to be submitted at end of turn|queued follow-up inputs)",
      "description": "Codex visible pending-message signature.",
      "flags": 2
    }
  },
  "prompts": {
    "first": "Count from 1 to 100 slowly, printing one number per second. Do not edit files.",
    "second": "Now count from 101 to 150 slowly, printing one number per second."
  },
  "steps": [
    {
      "kind": "wait_seconds",
      "seconds": 1.0,
      "note": "let the provider finish painting"
    },
    {
      "kind": "wait_for_pattern",
      "pattern": "ready",
      "timeout_seconds": 90,
      "required": true
    },
    {
      "kind": "send_text",
      "text": "{{first}}"
    },
    {
      "kind": "wait_seconds",
      "seconds": 0.5,
      "note": "let text settle before pressing Enter"
    },
    {
      "kind": "send_key",
      "key": "Enter"
    },
    {
      "kind": "wait_for_pattern",
      "pattern": "active",
      "timeout_seconds": 15,
      "required": true
    },
    {
      "kind": "wait_seconds",
      "seconds": 3.0,
      "note": "let the first prompt commit before submitting a follow-up"
    },
    {
      "kind": "send_text",
      "text": "{{second}}"
    },
    {
      "kind": "wait_seconds",
      "seconds": 0.5,
      "note": "let text settle before pressing Enter"
    },
    {
      "kind": "send_key",
      "key": "Enter"
    },
    {
      "kind": "wait_for_pattern",
      "pattern": "pending",
      "timeout_seconds": 30,
      "required": true
    },
    {
      "kind": "wait_for_pattern_absent",
      "pattern": "pending",
      "timeout_seconds": 120,
      "required": true
    },
    {
      "kind": "wait_for_pattern",
      "pattern": "active",
      "timeout_seconds": 30,
      "required": true
    },
    {
      "kind": "wait_for_pattern_absent",
      "pattern": "active",
      "timeout_seconds": 300,
      "required": true
    },
    {
      "kind": "wait_for_pattern",
      "pattern": "ready",
      "timeout_seconds": 120,
      "required": true
    },
    {
      "kind": "wait_seconds",
      "seconds": 2.0,
      "note": "hold the final ready posture"
    }
  ]
}
