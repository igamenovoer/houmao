{
  "id": "stale-known-failure-before-later-success",
  "description": "Placeholder corpus case for a later success after an older visible failure remains in scrollback.",
  "launch": {
    "ready_timeout_seconds": 45.0,
    "settle_seconds": 1.0,
    "sample_interval_seconds": 0.25
  },
  "steps": [
    {
      "action": "wait_for_ready",
      "name": "wait-ready",
      "timeout_seconds": 45.0
    },
    {
      "action": "send_text",
      "name": "send-later-success-prompt",
      "text": "Reply with the single word RECOVERED and stop.",
      "submit": true
    },
    {
      "action": "wait_for_pattern",
      "name": "wait-for-recovery",
      "pattern": "(?m)^● RECOVERED$",
      "timeout_seconds": 90.0
    }
  ]
}
