{
  "id": "interrupt-after-active",
  "description": "Submit a longer prompt, wait for active evidence, then interrupt Claude.",
  "launch": {
    "ready_timeout_seconds": 45.0,
    "settle_seconds": 1.0,
    "sample_interval_seconds": 0.2
  },
  "steps": [
    {
      "action": "wait_for_ready",
      "name": "wait-ready",
      "timeout_seconds": 45.0
    },
    {
      "action": "send_text",
      "name": "send-long-prompt",
      "text": "Explore the repository structure carefully, explain it in depth, and do not stop early.",
      "submit": true
    },
    {
      "action": "wait_for_pattern",
      "name": "wait-for-active-footer",
      "pattern": "esc to|[A-Za-z][A-Za-z-]+ing…",
      "timeout_seconds": 90.0
    },
    {
      "action": "send_key",
      "name": "interrupt",
      "key": "C-c"
    },
    {
      "action": "wait_for_pattern",
      "name": "wait-for-interrupted",
      "pattern": "Interrupted\\s+·\\s+What should Claude do instead\\?",
      "timeout_seconds": 30.0
    }
  ]
}
