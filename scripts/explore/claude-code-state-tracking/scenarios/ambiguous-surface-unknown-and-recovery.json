{
  "id": "ambiguous-surface-unknown-and-recovery",
  "description": "Drive prompt-area ambiguity, then recover to a clear ready posture.",
  "launch": {
    "ready_timeout_seconds": 45.0,
    "settle_seconds": 1.0,
    "sample_interval_seconds": 0.2
  },
  "steps": [
    {
      "action": "wait_for_ready",
      "name": "wait-ready",
      "timeout_seconds": 45.0
    },
    {
      "action": "send_text",
      "name": "open-slash-menu",
      "text": "/",
      "submit": false
    },
    {
      "action": "wait_seconds",
      "name": "hold-ambiguous-ui",
      "seconds": 1.0
    },
    {
      "action": "send_key",
      "name": "dismiss-ambiguous-ui",
      "key": "Escape"
    },
    {
      "action": "wait_for_ready",
      "name": "wait-ready-recovered",
      "timeout_seconds": 20.0
    }
  ]
}

