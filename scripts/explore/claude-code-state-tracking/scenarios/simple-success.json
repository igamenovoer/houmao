{
  "id": "simple-success",
  "description": "Submit one short prompt and let Claude return to a settled success surface.",
  "launch": {
    "ready_timeout_seconds": 45.0,
    "settle_seconds": 1.0,
    "sample_interval_seconds": 0.2
  },
  "steps": [
    {
      "action": "wait_for_ready",
      "name": "wait-ready",
      "timeout_seconds": 45.0
    },
    {
      "action": "send_text",
      "name": "send-success-prompt",
      "text": "Reply with the single word READY and stop.",
      "submit": true
    },
    {
      "action": "wait_for_pattern",
      "name": "wait-for-completion-marker",
      "pattern": "(?m)^● READY$",
      "timeout_seconds": 90.0
    },
    {
      "action": "wait_seconds",
      "name": "settle",
      "seconds": 2.0
    }
  ]
}
