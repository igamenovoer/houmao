{
  "id": "mid-turn-network-failure-injected",
  "description": "Attach network syscall fault injection while a Claude turn is active.",
  "launch": {
    "ready_timeout_seconds": 45.0,
    "settle_seconds": 1.0,
    "sample_interval_seconds": 0.2
  },
  "steps": [
    {
      "action": "wait_for_ready",
      "name": "wait-ready",
      "timeout_seconds": 45.0
    },
    {
      "action": "send_text",
      "name": "send-midturn-prompt",
      "text": "Research the repository and summarize several modules in detail before stopping.",
      "submit": true
    },
    {
      "action": "wait_for_pattern",
      "name": "wait-for-active-footer",
      "pattern": "Running…|[A-Za-z][A-Za-z-]+ing…",
      "timeout_seconds": 90.0
    },
    {
      "action": "attach_fault_injection",
      "name": "inject-midturn-fault",
      "fault_injection": {
        "mode": "attach_strace_inject",
        "syscall": "recvmsg",
        "error": "ECONNRESET",
        "when": "1"
      }
    },
    {
      "action": "wait_seconds",
      "name": "wait-after-fault",
      "seconds": 20.0
    }
  ]
}
