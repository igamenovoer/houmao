{
  "id": "ready-noise-without-submit",
  "description": "Create prompt-area churn without starting a submitted turn.",
  "launch": {
    "ready_timeout_seconds": 45.0,
    "settle_seconds": 1.0,
    "sample_interval_seconds": 0.2
  },
  "steps": [
    {
      "action": "wait_for_ready",
      "name": "wait-ready",
      "timeout_seconds": 45.0
    },
    {
      "action": "send_text",
      "name": "type-slash",
      "text": "/",
      "submit": false
    },
    {
      "action": "wait_seconds",
      "name": "hold-slash-menu",
      "seconds": 1.5
    },
    {
      "action": "send_key",
      "name": "dismiss-slash-menu",
      "key": "BSpace"
    },
    {
      "action": "wait_seconds",
      "name": "settle",
      "seconds": 1.0
    }
  ]
}

