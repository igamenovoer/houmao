{
  "id": "process-killed-tmux-still-alive",
  "description": "Kill the Claude process while keeping the tmux target observable.",
  "launch": {
    "ready_timeout_seconds": 45.0,
    "settle_seconds": 1.0,
    "sample_interval_seconds": 0.2
  },
  "steps": [
    {
      "action": "wait_seconds",
      "name": "give-process-time-to-start",
      "seconds": 3.0
    },
    {
      "action": "kill_launch_process",
      "name": "kill-process"
    },
    {
      "action": "wait_seconds",
      "name": "observe-post-kill",
      "seconds": 3.0
    }
  ]
}

