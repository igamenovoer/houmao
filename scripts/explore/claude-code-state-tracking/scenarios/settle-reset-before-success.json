{
  "id": "settle-reset-before-success",
  "description": "Capture a longer answer where the completion surface may keep changing before final settlement.",
  "launch": {
    "ready_timeout_seconds": 45.0,
    "settle_seconds": 1.0,
    "sample_interval_seconds": 0.2
  },
  "steps": [
    {
      "action": "wait_for_ready",
      "name": "wait-ready",
      "timeout_seconds": 45.0
    },
    {
      "action": "send_text",
      "name": "send-long-answer-prompt",
      "text": "Write a long, numbered explanation of ten interesting architecture patterns, each with two sentences.",
      "submit": true
    },
    {
      "action": "wait_for_pattern",
      "name": "wait-for-answer-growth",
      "pattern": "(?m)^● 1\\. Event Sourcing",
      "timeout_seconds": 120.0
    },
    {
      "action": "wait_seconds",
      "name": "settle",
      "seconds": 3.0
    }
  ]
}
